@model IEnumerable<ReservaHotel.Models.Hotel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-building"></i> Gestión de Hoteles</h2>
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Agregar Hotel</a>
        }
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Dirección</th>
                <th>Precio/Noche</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nombre</td>
                    <td>@item.Direccion</td>
                    <td>@item.PrecioPorNoche.ToString("C")</td>
                    <td>
                        @if (User.IsInRole("Administrador"))
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Borrar</a>
                        }
                        <a asp-controller="Reservas" asp-action="Reservar" asp-route-hotelId="@item.Id" class="btn btn-sm btn-success">Reservar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>