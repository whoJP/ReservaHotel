@model ReservaHotel.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard Administrador</h2>

    <!-- Tarjetas de resumen -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card text-white bg-primary shadow">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Hoteles</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalHoteles</h2>
                    </div>
                    <i class="bi bi-building fs-1 opacity-75"></i>
                </div>
                <div class="card-footer">
                    <a asp-controller="Hoteles" asp-action="Index" class="text-white text-decoration-none">
                        Ver hoteles →
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success shadow">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Usuarios</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalUsuarios</h2>
                    </div>
                    <i class="bi bi-people fs-1 opacity-75"></i>
                </div>
                <div class="card-footer">
                    <span class="text-white">Usuarios registrados</span>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-warning shadow">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title">Total Reservas</h6>
                        <h2 class="fw-bold mb-0">@Model.TotalReservas</h2>
                    </div>
                    <i class="bi bi-calendar-check fs-1 opacity-75"></i>
                </div>
                <div class="card-footer">
                    <a asp-controller="Reservas" asp-action="Index" class="text-white text-decoration-none">
                        Ver reservas →
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row g-4">
        <div class="col-md-7">
            <div class="card shadow">
                <div class="card-header bg-light fw-bold">
                    <i class="bi bi-bar-chart"></i> Reservas por Mes (@DateTime.Now.Year)
                </div>
                <div class="card-body">
                    <canvas id="chartReservasMes" height="250"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-light fw-bold">
                    <i class="bi bi-pie-chart"></i> Hoteles más Reservados
                </div>
                <div class="card-body">
                    <canvas id="chartHoteles" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const meses = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

        const dataMes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.ReservasPorMes.Select(x => new { mes = int.Parse(x.Mes), cantidad = x.Cantidad })
            ));

        const cantidadesMes = Array(12).fill(0);
        dataMes.forEach(d => cantidadesMes[d.mes - 1] = d.cantidad);

        new Chart(document.getElementById('chartReservasMes'), {
        type: 'bar',
        data: {
        labels: meses,
        datasets: [{
        label: 'Reservas',
        data: cantidadesMes,
        backgroundColor: 'rgba(13,110,253,0.7)',
        borderColor: 'rgba(13,110,253,1)',
        borderWidth: 1
        }]
        },
        options: {
        responsive: true,
        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
        });

        const dataHoteles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.HotelesMasReservados.Select(x => new { nombre = x.NombreHotel, cantidad = x.CantidadReservas })
            ));

        if (dataHoteles.length > 0) {
        new Chart(document.getElementById('chartHoteles'), {
        type: 'doughnut',
        data: {
        labels: dataHoteles.map(d => d.nombre),
        datasets: [{
        data: dataHoteles.map(d => d.cantidad),
        backgroundColor: ['#0d6efd','#198754','#ffc107','#dc3545','#0dcaf0']
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { position: 'bottom' } }
        }
        });
        } else {
        document.getElementById('chartHoteles').parentElement.innerHTML =
        '<p class="text-muted text-center mt-4">Sin datos de reservas aún.</p>';
        }
    </script>
}