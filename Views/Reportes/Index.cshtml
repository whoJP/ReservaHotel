@{
    ViewData["Title"] = "Reportes PDF";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-file-earmark-pdf"></i> Generador de Reportes PDF</h2>

    <div class="row g-4">
        <!-- Reporte 1 -->
        <div class="col-md-4">
            <div class="card shadow text-center h-100">
                <div class="card-body py-5">
                    <i class="bi bi-list-check display-3 text-primary mb-3"></i>
                    <h5 class="fw-bold">Lista de Reservas</h5>
                    <p class="text-muted">Reporte completo con todas las reservas del sistema.</p>
                    <a asp-action="ListaReservas" class="btn btn-primary" target="_blank">
                        <i class="bi bi-download"></i> Descargar PDF
                    </a>
                </div>
            </div>
        </div>

        <!-- Reporte 2 -->
        <div class="col-md-4">
            <div class="card shadow text-center h-100">
                <div class="card-body py-5">
                    <i class="bi bi-person-lines-fill display-3 text-success mb-3"></i>
                    <h5 class="fw-bold">Reservas por Usuario</h5>
                    <p class="text-muted">Reservas agrupadas por cada cliente registrado.</p>
                    <a asp-action="ReservasPorUsuario" class="btn btn-success" target="_blank">
                        <i class="bi bi-download"></i> Descargar PDF
                    </a>
                </div>
            </div>
        </div>

        <!-- Reporte 3 -->
        <div class="col-md-4">
            <div class="card shadow text-center h-100">
                <div class="card-body py-5">
                    <i class="bi bi-bar-chart-fill display-3 text-danger mb-3"></i>
                    <h5 class="fw-bold">Hoteles más Reservados</h5> 
                    <p class="text-muted">Ranking de hoteles con mayor número de reservas.</p>
                    <a asp-action="HotelesMasReservados" class="btn btn-danger" target="_blank">
                        <i class="bi bi-download"></i> Descargar PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>