@model IEnumerable<ReservaHotel.Models.Hotel>

@{
    ViewData["Title"] = "Gestión de Hoteles";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-building"></i> Gestión de Hoteles</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Nuevo Hotel
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nombre</th>
                        <th>Dirección</th>
                        <th>Precio/Noche</th>
                        <th>Descripción</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hotel in Model)
                    {
                        <tr>
                            <td><strong>@hotel.Nombre</strong></td>
                            <td>@hotel.Direccion</td>
                            <td class="text-success fw-bold">$@hotel.PrecioNoche.ToString("N2")</td>
                            <td>
                                @(hotel.Descripcion.Length > 60
                                                            ? hotel.Descripcion.Substring(0, 60) + "..."
                                                            : hotel.Descripcion)
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@hotel.Id"
                                   class="btn btn-sm btn-info text-white">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@hotel.Id"
                                   class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@hotel.Id"
                                   class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">
                                No hay hoteles registrados. ¡Crea el primero!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>