@model ReservaHotel.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-calendar-plus"></i> Nueva Reserva</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="HotelId" class="form-label fw-bold"></label>
                            <select asp-for="HotelId" asp-items="ViewBag.HotelId"
                                    class="form-select">
                                <option value="">-- Selecciona un hotel --</option>
                            </select>
                            <span asp-validation-for="HotelId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaInicio" class="form-label fw-bold"></label>
                            <input asp-for="FechaInicio" class="form-control"
                                   type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="FechaInicio" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaFin" class="form-label fw-bold"></label>
                            <input asp-for="FechaFin" class="form-control"
                                   type="date" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="FechaFin" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Confirmar Reserva
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}