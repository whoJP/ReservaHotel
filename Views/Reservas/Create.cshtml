@model ReservaHotel.Models.Reserva

@{
    ViewData["Title"] = "Nueva Reserva";
    var hoy = DateTime.Today.ToString("yyyy-MM-dd");
    var maxFecha = DateTime.Today.AddYears(1).ToString("yyyy-MM-dd");
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-calendar-plus"></i> Nueva Reserva</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="HotelId" class="form-label fw-bold">Hotel</label>
                            <select asp-for="HotelId" asp-items="ViewBag.HotelId" class="form-select">
                                <option value="">-- Selecciona un hotel --</option>
                            </select>
                            <span asp-validation-for="HotelId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaInicio" class="form-label fw-bold">Fecha de Inicio</label>
                            <input asp-for="FechaInicio"
                                   class="form-control"
                                   type="date"
                                   min="@hoy"
                                   max="@maxFecha"
                                   id="fechaInicio" />
                            <span asp-validation-for="FechaInicio" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FechaFin" class="form-label fw-bold">Fecha de Fin</label>
                            <input asp-for="FechaFin"
                                   class="form-control"
                                   type="date"
                                   min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                   max="@DateTime.Today.AddYears(1).AddDays(30).ToString("yyyy-MM-dd")"
                                   id="fechaFin" />
                            <span asp-validation-for="FechaFin" class="text-danger"></span>
                        </div>

                        <div class="alert alert-info py-2 small">
                            <i class="bi bi-info-circle"></i>
                            Duración mínima: <strong>1 noche</strong> —
                            Duración máxima: <strong>30 días</strong>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Confirmar Reserva
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Ajusta el mínimo de FechaFin automáticamente al elegir FechaInicio
        document.getElementById('fechaInicio').addEventListener('change', function () {
            const inicio = new Date(this.value);
            if (!isNaN(inicio)) {
                // Mínimo: día siguiente al inicio
                const minFin = new Date(inicio);
                minFin.setDate(minFin.getDate() + 1);

                // Máximo: 30 días desde el inicio
                const maxFin = new Date(inicio);
                maxFin.setDate(maxFin.getDate() + 30);

                const finInput = document.getElementById('fechaFin');
                finInput.min = minFin.toISOString().split('T')[0];
                finInput.max = maxFin.toISOString().split('T')[0];
                finInput.value = '';
            }
        });
    </script>
}