@model IEnumerable<ReservaHotel.Models.Reserva>

@{
    ViewData["Title"] = "Mis Reservas";
    bool esAdmin = User.IsInRole("Administrador");
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-calendar-check"></i> @(esAdmin ? "Todas las Reservas" : "Mis Reservas")</h2>
        @if (!esAdmin)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Nueva Reserva
            </a>
        }
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        @if (esAdmin)
                        {
                            <th>Cliente</th>
                        }
                        <th>Hotel</th>
                        <th>Fecha Inicio</th>
                        <th>Fecha Fin</th>
                        <th>Noches</th>
                        <th>Total</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reserva in Model)
                    {
                        <tr>
                            @if (esAdmin)
                            {
                                <td>@reserva.Usuario?.NombreCompleto</td>
                            }
                            <td><strong>@reserva.Hotel?.Nombre</strong></td>
                            <td>@reserva.FechaInicio.ToString("dd/MM/yyyy")</td>
                            <td>@reserva.FechaFin.ToString("dd/MM/yyyy")</td>
                            <td>@reserva.TotalNoches</td>
                            <td class="text-success fw-bold">
                                $@((reserva.TotalNoches * (reserva.Hotel?.PrecioNoche ?? 0)).ToString("N2"))
                            </td>
                            <td class="text-center">
                                <a asp-action="Delete" asp-route-id="@reserva.Id"
                                   class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Cancelar
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No hay reservas registradas.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>